{
  "name": "ngssm-element",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "build:ngssm-element": "ng build --project=ngssm-element",
    "test:ngssm-element": "ng test --no-watch --browsers=ChromeHeadless --project=ngssm-element --code-coverage",
    "build:element-provider": "ng build --project=element-provider && rm -rf ./src/assets/element-provider && mkdir -p ./src/assets/element-provider && cp -r ./dist/element-provider/browser/* ./src/assets/element-provider && mv ./src/assets/element-provider/main*js ./src/assets/element-provider/element-provider.js",
    "build:simple-element-provider": "ng build --project=simple-element-provider && rm -rf ./src/assets/simple-element-provider && mkdir -p ./src/assets/simple-element-provider && cp -r ./dist/simple-element-provider/browser/* ./src/assets/simple-element-provider && mv ./src/assets/simple-element-provider/main*js ./src/assets/simple-element-provider/simple-element-provider.js",
    "build:all": "npm run build:ngssm-element && npm run build:element-provider && npm run build:simple-element-provider"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.3",
    "@angular/cdk": "22.0.2",
    "@angular/common": "22.0.3",
    "@angular/compiler": "22.0.3",
    "@angular/core": "22.0.3",
    "@angular/elements": "22.0.3",
    "@angular/forms": "22.0.3",
    "@angular/material": "22.0.2",
    "@angular/platform-browser": "22.0.3",
    "@angular/platform-browser-dynamic": "22.0.3",
    "@angular/router": "22.0.3",
    "@fortawesome/fontawesome-free": "7.3.0",
    "angular-oauth2-oidc": "22.0.2",
    "immutability-helper": "3.1.1",
    "luxon": "3.7.2",
    "ngssm-remote-data": "22.0.0",
    "ngssm-store": "22.0.0",
    "ngssm-toolkit": "22.0.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.4",
    "@angular/cli": "22.0.4",
    "@angular/compiler-cli": "22.0.3",
    "@eslint/js": "10.0.1",
    "@types/jasmine": "6.0.0",
    "@types/luxon": "3.7.2",
    "angular-eslint": "22.0.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "istanbul-lib-instrument": "6.0.3",
    "jasmine-core": "6.3.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "mkdirp": "3.0.1",
    "ng-packagr": "22.0.0",
    "ngssm-schematics": "22.0.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  }
}
